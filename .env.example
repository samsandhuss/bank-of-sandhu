# .env.example — copy to .env and fill in.
# DO NOT commit a real .env. (See .gitignore.)

# Which brand to run. Options: sandhu, mal
BRAND=sandhu

# Anthropic API key for the chatbot (Block E onwards)
ANTHROPIC_API_KEY=sk-ant-...

# Port for BFF (Express). Frontend (Vite) defaults to 5173.
PORT=3001

# Demo mode — pre-fills KYC, skips real verification. Always true in this prototype.
DEMO_MODE=true
